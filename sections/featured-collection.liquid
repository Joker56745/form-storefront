{%- liquid
  assign collection = collections[section.settings.collection]
  assign limit = section.settings.products_to_show
-%}

<section class="form-section form-section--surface">
  <div class="form-container">
    <div class="form-section__head">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="form-eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        <h2 class="form-heading">{{ section.settings.heading | escape }}</h2>
      </div>
      {%- if collection != blank and section.settings.show_view_all -%}
        <a href="{{ collection.url }}" class="form-btn form-btn--secondary">View all</a>
      {%- endif -%}
    </div>

    {%- if collection != blank and collection.products_count > 0 -%}
      <div class="form-product-grid">
        {%- for product in collection.products limit: limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="form-lead">
        Assign a collection in the theme editor. Add products in Shopify Admin to populate the grid.
      </p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Daily formulas"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Core stack"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all link",
      "default": true
    }
  ],
  "presets": [{ "name": "Featured collection" }]
}
{% endschema %}
