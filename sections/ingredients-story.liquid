<section class="form-section form-section--surface">
  <div class="form-container form-story">
    <div>
      {%- if section.settings.eyebrow != blank -%}
        <p class="form-eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h2 class="form-heading">{{ section.settings.heading | escape }}</h2>
      {%- if section.settings.text != blank -%}
        <p class="form-lead" style="margin-top: 1rem;">{{ section.settings.text | escape }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="form-story__list">
          {%- for block in section.blocks -%}
            <li {{ block.shopify_attributes }}>{{ block.settings.item | escape }}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="form-btn form-btn--primary" style="margin-top: 1.75rem;">
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div>

    <div class="form-hero__visual">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
      {%- else -%}
        <div class="form-hero__visual-placeholder">Ingredient / lab imagery</div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Ingredients story",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Formulation" },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Only what your body can use."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "We source bioavailable forms, publish full supplement facts, and formulate with clinicians — not influencers."
    },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "button_label", "label": "Button", "default": "Read our standards" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Bullet",
      "settings": [
        { "type": "text", "id": "item", "label": "Text", "default": "Chelated minerals for absorption" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Ingredients story",
      "blocks": [
        { "type": "point", "settings": { "item": "Chelated minerals for absorption" } },
        { "type": "point", "settings": { "item": "Delayed-release capsules where it matters" } },
        { "type": "point", "settings": { "item": "No artificial dyes or titanium dioxide" } }
      ]
    }
  ]
}
{% endschema %}
