<section class="form-section" style="padding-top: 2rem;">
  <div class="form-container">
    <h1 class="form-heading" style="margin-bottom: 2rem;">Cart</h1>

    {%- if cart.item_count == 0 -%}
      <p class="form-lead">Your cart is empty.</p>
      <a href="{{ routes.all_products_collection_url }}" class="form-btn form-btn--primary" style="margin-top: 1.5rem;">
        Shop formulas
      </a>
    {%- else -%}
      <form action="{{ routes.cart_url }}" method="post">
        <ul style="list-style: none; margin: 0; padding: 0; display: grid; gap: 1.5rem;">
          {%- for item in cart.items -%}
            <li style="display: grid; grid-template-columns: 5rem 1fr auto; gap: 1rem; align-items: center; padding-bottom: 1.5rem; border-bottom: 1px solid var(--form-border);">
              {%- if item.image -%}
                <img src="{{ item.image | image_url: width: 160 }}" alt="{{ item.title | escape }}" width="80" height="80" style="border-radius: 0.5rem; object-fit: cover;">
              {%- endif -%}
              <div>
                <a href="{{ item.url }}" style="font-weight: 600; text-decoration: none;">{{ item.product.title | escape }}</a>
                {%- unless item.product.has_only_default_variant -%}
                  <p class="form-lead" style="margin: 0.25rem 0 0; font-size: 0.875rem;">{{ item.variant.title | escape }}</p>
                {%- endunless -%}
                <p style="margin: 0.5rem 0 0; font-weight: 600;">{{ item.final_line_price | money }}</p>
              </div>
              <div>
                <label class="visually-hidden" for="Quantity-{{ item.key }}">Quantity</label>
                <input
                  id="Quantity-{{ item.key }}"
                  type="number"
                  name="updates[]"
                  value="{{ item.quantity }}"
                  min="0"
                  style="width: 4rem; min-height: 2.5rem; padding: 0 0.5rem; border: 1px solid var(--form-border); border-radius: 0.5rem;"
                >
              </div>
            </li>
          {%- endfor -%}
        </ul>

        <div style="margin-top: 2rem; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 1rem;">
          <p style="font-size: 1.125rem; font-weight: 600; margin: 0;">
            Subtotal: {{ cart.total_price | money }}
          </p>
          <div style="display: flex; gap: 0.75rem;">
            <button type="submit" name="update" class="form-btn form-btn--secondary">Update</button>
            <button type="submit" name="checkout" class="form-btn form-btn--primary">Checkout</button>
          </div>
        </div>
      </form>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
