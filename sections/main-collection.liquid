<section class="form-section" style="padding-top: 2rem;">
  <div class="form-container">
    <header class="form-section__head">
      <div>
        <p class="form-eyebrow">Shop</p>
        <h1 class="form-heading">{{ collection.title | escape }}</h1>
        {%- if collection.description != blank -%}
          <p class="form-lead" style="margin-top: 1rem;">{{ collection.description }}</p>
        {%- endif -%}
      </div>
    </header>

    {%- paginate collection.products by 12 -%}
      <div class="form-product-grid">
        {%- for product in collection.products -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="form-lead" style="margin-top: 2rem;" aria-label="Pagination">
          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}">← Previous</a>
          {%- endif -%}
          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" style="margin-left: 1rem;">Next →</a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection",
  "settings": []
}
{% endschema %}
